# ===================================
# KodetoCareer API — Environment Config
# ===================================

# App
NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_URL=http://localhost:5173

# Database — Neon.tech (FREE), Supabase, or Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kodetocareer?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/kodetocareer?schema=public"

# Redis — Upstash (FREE) or Local Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
REDIS_URL=redis://localhost:6379

# Auth — Self-generated keys (free)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then paste the contents as single-line with \n for newlines
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30
REFRESH_TOKEN_SECRET=your-64-char-random-secret-string-here-replace-me-now-please

# Cloudflare R2 (FREE — S3-compatible)
CF_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=kodetocareer-dev
R2_PUBLIC_URL=https://cdn.kodetocareer.com

# Email — Resend (FREE 3,000/month)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@kodetocareer.com

# Push Notifications — Firebase FCM (FREE)
FCM_SERVER_KEY=your_firebase_server_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# Monitoring — Sentry (FREE tier)
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bcrypt
BCRYPT_ROUNDS=12
